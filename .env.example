# Astera dashboard daily cron re-sync window (weekdays); use rolling 30 for manual backfill
# ASTERA_DASHBOARD_CRON_WINDOW_DAYS=7
# SHEETS_API_MIN_INTERVAL_MS=1500

# MedOnc production alerts (separate from Astera radiology + test_alerts ops)
# SLACK_CHANNEL_MEDONC_ALERTS=your_medonc_channel_id

# Optional: deep link template for denial cards (use {order_id} placeholder)
# ONE_RISA_ORDER_URL_TEMPLATE=https://app.example.com/orders/{order_id}

# Astera dashboard Sheets API throttling (avoid 60 reads/min quota)
# SHEETS_API_MIN_INTERVAL_MS=2800
# ASTERA_DASHBOARD_CRON_WINDOW_DAYS=3
# ASTERA_DASHBOARD_SYNC_DELAY_MS=8000
# ASTERA_DASHBOARD_SHEETS_ID=your_google_sheet_id
BIGQUERY_LOCATION=us-central1

# Payer Treatment Aging Sheet
VITE_PAYER_AGING_SHEETS_ID=your_payer_aging_sheets_id

# Cloud Scheduler / Cloud Run cron API (optional — use GitHub Actions instead)
# SCHEDULER_STATE_BACKEND=firestore   # auto on Cloud Run / GitHub Actions
# CRON_SECRET=optional_local_secret   # for local cron:api testing
# CRON_ALLOW_UNAUTHENTICATED=true     # local dev only

# GitHub Actions secrets (Settings → Secrets → Actions):
#   DASHBOARD_ENV_FILE — paste full .env contents (include SLACK_CHANNEL_TEST_ALERTS)
#   GCP_SA_KEY         — service account JSON (BigQuery + Sheets + Firestore)
