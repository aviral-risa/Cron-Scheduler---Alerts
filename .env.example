# Google OAuth Client ID (required for authentication)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_ID=your_google_client_id_here

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google Sheets Configuration (Multi-Spreadsheet Architecture)
# Legacy single spreadsheet (DEPRECATED - for rollback only)
VITE_GOOGLE_SHEETS_ID=your_legacy_sheets_id

# Multi-spreadsheet architecture (NEW - recommended)
VITE_RAW_DATA_SHEETS_ID=your_raw_data_sheets_id        # Stores: orders_raw_hourly, config_sync_log
VITE_DASHBOARD_SHEETS_ID=your_dashboard_sheets_id      # Stores: metrics, daily_summary, config
VITE_UNIQUE_STATUS_SHEETS_ID=your_unique_status_sheets_id  # Stores: unique_orders_status
VITE_QUEUE_SHEETS_ID=your_queue_sheets_id              # Stores: queue_daily_log (daily queue snapshots at 11:59 PM IST)

# Service account credentials (used for all sheets)
VITE_GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
VITE_GOOGLE_PRIVATE_KEY=your_private_key_here

# Tech Metrics Google Sheet (EV Metrics) - uses same service account
VITE_TECH_METRICS_SHEETS_ID=17vqawGCudDejGH8dSD9oPjnLAEDlkw195X6zAbt2O2I

# Feature Flags
ENABLE_UNIQUE_ORDER_STATUS_SYNC=false  # Enable unique order status tracking (set to true to enable)

# Firebase Firestore Collection Path
VITE_FIRESTORE_COLLECTION=medical_pa_orders

# Slack Webhook URLs (for daily alerts)
# Get webhook URLs from: https://api.slack.com/apps > Your App > Incoming Webhooks
SLACK_WEBHOOK_NYCBS=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK_CHC=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK_MBPCC=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_WEBHOOK_UCBC=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

