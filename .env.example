SLACK_CHANNEL=C0BEP0W1WAK
SLACK_CHANNEL_ASTERA_RADIOLOGY_INTERNAL=C09K4FFGV7H
SLACK_CHANNEL_ASTERA_RADIOLOGY_GROUP=C09K4FFGV7H

